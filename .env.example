INTELLIGENCE_PASSWORD=
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://127.0.0.1:3001

GHL_API_KEY=

# Jacob Module 1 — call log tab (publish sheet / correct gid). Not GHL API — Sheet rows with Contact ID or Phone + date.
JACOB_CALL_LOG_SHEET_ID=
JACOB_CALL_LOG_GID=0
# Default true: rows with blank Direction count as outbound (typical for outbound-only exports). Set false to require explicit outbound.
JACOB_CALL_LOG_ASSUME_OUTBOUND=true
# Built-in Jacob setter map is always merged first. Optional published tab (Filter Value → Setter); merge order: built-in → this sheet → JSON below.
JACOB_SETTER_ASSIGNMENTS_SHEET_ID=
JACOB_SETTER_ASSIGNMENTS_GID=0
# Map GHL opportunity "source" string → agent name for Assigned vs Called (JSON object). Example: {"Facebook":"Juan","fb lead form":"Juan","Website":"Leo"}
JACOB_SOURCE_AGENT_JSON=
# Optional override; defaults to SCORING_SHEET_ID in code
JACOB_INTELLIGENCE_SHEET_ID=
JACOB_RECONCILIATION_TAB_NAME=Assigned vs Called
# Google service account JSON (single line or paste) for Sheets API sync
GOOGLE_SERVICE_ACCOUNT_JSON=
# n8n / cron: POST /api/jacob/reconciliation/sync with Authorization: Bearer <secret>
JACOB_CRON_SECRET=

# Module 2 — Clio → n8n → POST log row (Bearer JACOB_CLIO_INBOUND_SECRET)
JACOB_CLIO_INBOUND_SECRET=
JACOB_CLIO_SYNC_TAB_NAME=Clio Sync
IGNITION_CLIO_LOG_URL=

SF_INSTANCE_URL=
SF_CLIENT_ID=
SF_CLIENT_SECRET=
SF_REFRESH_TOKEN=
