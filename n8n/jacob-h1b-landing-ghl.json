    {
      "parameters": {
        "jsCode": "const body = $json.body || $json;\nconst firstName = (body.first_name || '').toString().trim();\nconst lastName = (body.last_name || '').toString().trim();\nlet phone = (body.phone || '').toString().trim();\nconst email = (body.email || '').toString().trim();\nconst matter = (body.immigration_matter || 'Not specified').toString().trim();\n\n// Normalize phone - remove spaces, dashes, parens\nlet cleanPhone = phone.replace(/[\\s\\-\\(\\)]/g, '');\n\n// Detect international: if it starts with + and NOT +1, it's international\n// Also handle numbers that don't start with + but aren't 10-11 digit US numbers\nlet isInternational = false;\nif (cleanPhone.startsWith('+') && !cleanPhone.startsWith('+1')) {\n  isInternational = true;\n} else if (!cleanPhone.startsWith('+') && !cleanPhone.startsWith('1') && cleanPhone.length > 10) {\n  isInternational = true;\n}\n\n// For GHL, format US numbers with +1 prefix\nlet ghlPhone = cleanPhone;\nif (!isInternational) {\n  ghlPhone = cleanPhone.replace(/^\\+?1?/, '');\n  if (ghlPhone.length === 10) ghlPhone = '+1' + ghlPhone;\n}\n\n// For WATI, need number without + prefix\nlet watiPhone = cleanPhone.replace(/^\\+/, '');\n\nconst tags = ['Cold Paid Media', 'ai sdr start'];\nif (isInternational) tags.push('international');\n\nreturn [{\n  json: {\n    firstName,\n    lastName,\n    phone: ghlPhone,\n    watiPhone,\n    email,\n    matter,\n    source: 'Cold Paid Media',\n    tags,\n    isInternational,\n    hasContact: !!(phone || email)\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
